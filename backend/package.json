{
  "name": "catering-inventory-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade AI-powered catering inventory management backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "db:migrate": "tsx src/database/scripts/init-db.ts",
    "db:seed": "tsx src/database/seeds/seed.ts",
    "queue:worker": "tsx src/queue/workers/ai.worker.ts & tsx src/queue/workers/notification.worker.ts"
  },
  "keywords": [
    "catering",
    "inventory",
    "management",
    "ai",
    "realtime",
    "barcode",
    "scanning"
  ],
  "author": "Enterprise AI Solutions",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "socket.io-redis": "^6.1.1",
    "redis": "^4.6.7",
    "bullmq": "^4.10.0",
    "pg": "^8.10.0",
    "pgvector": "^0.1.6",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "joi": "^17.11.0",
    "axios": "^1.6.2",
    "openai": "^4.20.0",
    "tesseract.js": "^4.1.1",
    "jsqr": "^1.4.0",
    "dayjs": "^1.11.10",
    "pdfkit": "^0.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/jest": "^29.5.7",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/bcryptjs": "^2.4.4",
    "typescript": "^5.2.2",
    "tsx": "^4.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.51.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "supertest": "^6.3.3"
  }
}
