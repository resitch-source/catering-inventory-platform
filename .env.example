# ============================================================================
# SERVER
# ============================================================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/catering_inventory
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# JWT
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-abc123
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters-abc123
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# SECURITY
# ============================================================================
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# GOOGLE SHEETS (MVP)
# ============================================================================
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_ID=

# ============================================================================
# OPENAI
# ============================================================================
OPENAI_API_KEY=

# ============================================================================
# LIVEKIT
# ============================================================================
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ============================================================================
# EMAIL
# ============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cateringinventory.local

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# FEATURES
# ============================================================================
ENABLE_AI_DETECTION=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_REALTIME_SYNC=true
